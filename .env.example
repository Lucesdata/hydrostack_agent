# ─────────────────────────────────────────────────────────────
# HydroStack — Environment Variables
# Copy this file to .env.local and fill in your keys.
# ─────────────────────────────────────────────────────────────

# Groq API — REQUIRED
# Powers the Hydro_Agent chat (/api/agent) with llama-3.3-70b-versatile.
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Anthropic API — OPTIONAL
# Only needed for photorealistic isometric diagram generation
# (/api/generate-isometric). The SVG diagram mode works without it.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# SECOP / Socrata App Token — OPTIONAL
# Used by the SECOP tender explorer (/licitaciones and the agent's
# search_secop_tenders tool). Without it, requests still work but are
# throttled to ~1k/hr per IP. Register a free app at:
# https://www.datos.gov.co/profile/edit/developer_settings
SECOP_APP_TOKEN=
